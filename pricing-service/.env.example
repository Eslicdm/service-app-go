# Pricing Service Database (MongoDB)
PRICING_DB_USERNAME=
PRICING_DB_PASSWORD=
PRICING_DB_NAME=
MONGO_HOST=pricing-service-db

# --- RabbitMQ ---
RABBITMQ_USERNAME=
RABBITMQ_PW=
