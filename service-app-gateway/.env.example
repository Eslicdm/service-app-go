# --- Downstream services (proxy targets) ---
MEMBER_REQUEST_SERVICE_URL=http://member-request-service:8084
MEMBER_SERVICE_URL=http://member-service:8081
PRICING_SERVICE_URL=http://pricing-service:8082

# --- Redis (rate limiter) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Keycloak (issuer URI used to build the JWKS URL)
KEYCLOAK_REALM_URL=http://keycloak:8080/realms/service-app-realm

# CORS allowed origin (Angular dev server)
CORS_ALLOWED_ORIGIN=http://localhost:4200

# Server port (aligned with the Spring gateway)
PORT=:8090
