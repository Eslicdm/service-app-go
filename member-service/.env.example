# Member Service Database (PostgreSQL)
MEMBER_DB_USERNAME=
MEMBER_DB_PASSWORD=
MEMBER_DB_NAME=
MEMBER_DB_HOST=member-service-db
MEMBER_DB_PORT=5432

# --- Redis (price cache + member requests hash) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ (price update consumer) ---
RABBITMQ_USERNAME=
RABBITMQ_PW=
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# --- Kafka (member request consumer) ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=member.requests.topic
KAFKA_GROUP_ID=member-service-group

# --- pricing-service URL (REST client for price cache fallback) ---
PRICING_SERVICE_URL=http://pricing-service:8082/api/v1

# Keycloak (issuer URI used to build the JWKS URL)
KEYCLOAK_REALM_URL=http://keycloak:8080/realms/service-app-realm

# Server port (aligned with the Spring member-service)
PORT=:8081
