# --- Redis (request dedup) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka (produce member requests) ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=member.requests.topic

# Keycloak (issuer URI used to build the JWKS URL)
KEYCLOAK_REALM_URL=http://keycloak:8080/realms/service-app-realm

# Server port (aligned with the Spring member-request-service)
PORT=:8084
